@{
    ViewData["Title"] = "Dashboard Elector";
    Layout = "_ElectorLayout";
    var eventsWithStatus = ViewBag.Events as List<dynamic>;
    var userName = User.Identity?.Name?.Split(' ')[0] ?? "Estudiante";
}

<div class="fade-in max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
        <h1 class="text-2xl font-bold mb-1">¡Hola, @userName!</h1>
        <p class="text-on-surface-variant flex items-center gap-1.5 mb-6">
            <span class="material-symbols-outlined text-base">badge</span> Estudiante
        </p>
        
        <h2 class="font-semibold flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined">campaign</span> Elecciones activas
        </h2>
        
        <div class="grid sm:grid-cols-2 gap-4">
            @if(eventsWithStatus != null && eventsWithStatus.Any())
            {
                foreach(var item in eventsWithStatus)
                {
                    var ev = item.Event as WahlMirai.Web.Models.VotingEvent;
                    bool hasVoted = item.HasVoted;

                    <div class="bg-surface-container-lowest rounded-xl border border-border-subtle shadow-card p-5">
                        <div class="flex justify-between items-start mb-3">
                            <div class="w-9 h-9 rounded-lg bg-surface-container flex items-center justify-center">
                                <span class="material-symbols-outlined">how_to_vote</span>
                            </div>
                            
                            @if(hasVoted)
                            {
                                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-status-voted/10 text-status-voted">Votado</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-status-pending/10 text-status-pending">
                                    <span class="w-1.5 h-1.5 rounded-full bg-status-pending"></span> Pendiente
                                </span>
                            }
                        </div>
                        <p class="font-semibold mb-1">@ev.Title</p>
                        <p class="text-sm text-on-surface-variant mb-4">@ev.Description</p>
                        
                        @if(hasVoted)
                        {
                            <a href="/Results/Index/@ev.Id" class="block text-center w-full border border-primary text-primary rounded-lg py-2 text-sm font-semibold hover:bg-surface-container-low transition-colors">
                                Ver resultados
                            </a>
                        }
                        else
                        {
                            <a href="/Elector/Votar/@ev.Id" class="block text-center w-full bg-primary text-on-primary rounded-lg py-2 text-sm font-semibold flex items-center justify-center gap-1 hover:bg-primary/90 transition-colors">
                                Ir a votar <span class="material-symbols-outlined text-base">arrow_forward</span>
                            </a>
                        }
                    </div>
                }
            }
            else
            {
                <div class="col-span-2 p-5 text-center text-on-surface-variant bg-surface-container-low rounded-xl">
                    No hay elecciones activas para tu grado en este momento.
                </div>
            }
        </div>
    </div>
    
    <div class="bg-surface-container-lowest rounded-xl border border-border-subtle shadow-card p-5 h-fit">
        <div class="flex items-center gap-2 mb-4">
            <div class="w-9 h-9 rounded-full bg-status-active/10 flex items-center justify-center text-status-active">
                <span class="material-symbols-outlined">encrypted</span>
            </div>
            <h3 class="font-semibold">Estado de participación</h3>
        </div>
        <div class="flex gap-2 items-start mb-4">
            <span class="material-symbols-outlined text-status-active mt-0.5">verified_user</span>
            <div>
                <p class="text-sm font-semibold">Voto anónimo garantizado</p>
                <p class="text-xs text-on-surface-variant">Tu selección se cifra y se disocia de tu identidad al confirmarla (RN-3, RF-M05-01).</p>
            </div>
        </div>
        <p class="text-xs uppercase text-on-surface-variant font-semibold mb-2">Historial reciente</p>
        
        @if(eventsWithStatus != null && eventsWithStatus.Any())
        {
            foreach(var item in eventsWithStatus)
            {
                var ev = item.Event as WahlMirai.Web.Models.VotingEvent;
                bool hasVoted = item.HasVoted;
                <div class="flex justify-between text-sm py-2 border-t border-border-subtle first:border-0">
                    <span>@ev.Title</span>
                    <span class="@(hasVoted ? "text-status-active" : "text-status-pending") font-semibold">
                        @(hasVoted ? "Completado" : "Pendiente")
                    </span>
                </div>
            }
        }
        else
        {
            <p class="text-sm text-on-surface-variant italic">No hay historial disponible.</p>
        }
    </div>
</div>
