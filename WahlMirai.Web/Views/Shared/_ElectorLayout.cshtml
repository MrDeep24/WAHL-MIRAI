@{
    Layout = "_Layout";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    
    bool isDashboard = currentAction.Equals("Dashboard", StringComparison.OrdinalIgnoreCase) && currentController.Equals("Elector", StringComparison.OrdinalIgnoreCase);
    bool isVotar = currentAction.Equals("Votar", StringComparison.OrdinalIgnoreCase) && currentController.Equals("Elector", StringComparison.OrdinalIgnoreCase);
    bool isResults = currentController.Equals("Results", StringComparison.OrdinalIgnoreCase);

    var eventIdObj = ViewContext.RouteData.Values["id"] ?? ViewBag.EventId;
    string eventId = eventIdObj?.ToString() ?? "";
}

<div class="min-h-screen">
    <header class="bg-surface-container-lowest border-b border-border-subtle px-8 py-4 flex items-center justify-between shadow-xs">
        <div class="flex items-center gap-8">
            <a href="/Elector/Dashboard" class="flex items-center gap-2 transition-opacity hover:opacity-90">
                <img src="/images/logo.png" alt="Wahl Mirai Logo" class="w-8 h-8 rounded-lg object-cover shadow-xs" />
                <span class="font-bold text-primary text-lg">Wahl Mirai</span>
            </a>
            <nav class="flex gap-6 items-center">
                <a href="/Elector/Dashboard" class="text-sm font-medium pb-1 border-b-2 transition-colors @(isDashboard ? "text-primary border-primary" : "text-on-surface-variant border-transparent hover:text-primary")">Panel de Control</a>
                
                @if (isVotar)
                {
                    <a href="@(!string.IsNullOrEmpty(eventId) ? $"/Elector/Votar/{eventId}" : "/Elector/Dashboard")" class="text-sm font-medium pb-1 border-b-2 text-primary border-primary transition-colors">Votar</a>
                }
                else if (isResults)
                {
                    <a href="@(!string.IsNullOrEmpty(eventId) ? $"/Results/Index/{eventId}" : "/Elector/Dashboard")" class="text-sm font-medium pb-1 border-b-2 text-primary border-primary transition-colors">Resultados</a>
                }
            </nav>
        </div>
        <div class="flex items-center gap-4">
            <a href="/Auth/Logout" class="flex items-center gap-2 text-sm font-medium text-on-surface-variant hover:text-error transition-colors px-3 py-1.5 rounded-lg hover:bg-surface-container-low">
                <span class="material-symbols-outlined text-lg">logout</span> Salir
            </a>
        </div>
    </header>
    <main class="p-8">
        @RenderBody()
    </main>
</div>

@await RenderSectionAsync("Scripts", required: false)


